{
  "name": "notes-backend",
  "version": "2.0.0",
  "description": "Production-grade Notes API built with Express, Prisma, PostgreSQL, and Docker",
  "bin": "bin/createNodejsApp.js",
  "main": "src/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/notes-backend.git"
  },
  "author": "Abdullah",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "start": "pm2 start ecosystem.config.json --no-daemon",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "prisma:generate": "npx prisma generate",
    "prisma:push": "npx prisma db push",
    "prisma:studio": "npx prisma studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.yml -f docker-compose.test.yml up",
    "prepare": "husky"
  },
  "keywords": [
    "node",
    "nodejs",
    "express",
    "expressjs",
    "rest",
    "rest-api",
    "api",
    "backend",
    "backend-api",
    "production-backend",
    "postgresql",
    "prisma",
    "sql",
    "docker",
    "docker-compose",
    "authentication",
    "jwt",
    "passport",
    "security",
    "rate-limiting",
    "winston",
    "logging",
    "health-check",
    "graceful-shutdown",
    "vitest",
    "testcontainers",
    "integration-testing",
    "eslint",
    "prettier",
    "pm2",
    "swagger",
    "openapi",
    "node-express",
    "production-ready"
  ],
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.0",
    "dayjs": "^1.11.13",
    "dotenv": "^10.0.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.2.0",
    "http-status": "^1.4.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.5.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pm2": "^5.4.3",
    "redis": "^5.12.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.0.0",
    "xss-clean": "^0.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^2.1.1",
    "faker": "^5.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "node-mocks-http": "^1.8.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "supertest": "^6.3.4",
    "testcontainers": "^11.14.0",
    "vitest": "^4.1.6"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
